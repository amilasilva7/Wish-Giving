generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String? 
  locationCoarse String?
  createdAt    DateTime @default(now())
  status       String   @default("active")
  emailVerifiedAt      DateTime?
  emailVerifyToken     String?   @unique
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  wishes       Wish[]   @relation("UserWishes")
  pledgesGiven Pledge[]  @relation("PledgeGiver")
  messagesSent Message[]  @relation("MessageSender")
  reports      Report[]  @relation("ReportReporter")
  blocksGiven  Block[]   @relation("Blocker")
  blocksReceived Block[] @relation("Blocked")
}

model Wish {
  id              String   @id @default(cuid())
  user            User     @relation("UserWishes", fields: [userId], references: [id])
  userId          String
  title           String
  description     String
  category        String
  budgetMin       Int?
  budgetMax       Int?
  budgetRangeId   String?
  occasionType    String
  visibility      String   @default("public")
  locationCoarse  String?
  status          String   @default("open")
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  pledges         Pledge[]
  conversations   Conversation[]

  @@index([status, visibility, category])
}

model Pledge {
  id         String   @id @default(cuid())
  wish       Wish     @relation(fields: [wishId], references: [id])
  wishId     String
  giver      User     @relation(fields: [giverUserId], references: [id], name: "PledgeGiver")
  giverUserId String
  message    String?
  status     String   @default("pending")
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  conversation Conversation?
}

model Conversation {
  id        String    @id @default(cuid())
  wish      Wish      @relation(fields: [wishId], references: [id])
  wishId    String
  pledge    Pledge?   @relation(fields: [pledgeId], references: [id])
  pledgeId  String?   @unique
  createdAt DateTime  @default(now())

  messages  Message[]
}

model Message {
  id              String       @id @default(cuid())
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  conversationId  String
  sender          User         @relation(fields: [senderUserId], references: [id], name: "MessageSender")
  senderUserId    String
  body            String
  createdAt       DateTime     @default(now())
}

model Block {
  id          String   @id @default(cuid())
  blocker     User     @relation("Blocker", fields: [blockerId], references: [id])
  blockerId   String
  blocked     User     @relation("Blocked", fields: [blockedId], references: [id])
  blockedId   String
  createdAt   DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model Report {
  id             String   @id @default(cuid())
  reporter       User     @relation(fields: [reporterUserId], references: [id], name: "ReportReporter")
  reporterUserId String
  targetType     String
  targetId       String
  reason         String
  status         String   @default("open")
  createdAt      DateTime @default(now())
}

